{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Bookings Created (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(ticketblitz_bookings_created_total[5m]) * 60",
          "legendFormat": "bookings/min"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Bookings Cancelled (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "rate(ticketblitz_bookings_cancelled_total[5m]) * 60",
          "legendFormat": "cancellations/min"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "fixedColor": "orange", "mode": "fixed" } } },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Seats Locked (total)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "ticketblitz_seats_locked_total",
          "legendFormat": "seats"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Payment Success vs Failure",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(ticketblitz_payments_processed_total{status=\"success\"}[5m]) * 60",
          "legendFormat": "success/min"
        },
        {
          "expr": "rate(ticketblitz_payments_processed_total{status=\"failed\"}[5m]) * 60",
          "legendFormat": "failed/min"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Payment Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ticketblitz_payments_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 duration"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Tickets Generated (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(ticketblitz_tickets_generated_total[5m]) * 60",
          "legendFormat": "tickets/min"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Ticket Generation Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ticketblitz_tickets_generation_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 generation"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Ticket Generation Errors & Duplicates Skipped",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [
        {
          "expr": "rate(ticketblitz_tickets_generation_errors_total[5m]) * 60",
          "legendFormat": "errors/min"
        },
        {
          "expr": "rate(ticketblitz_tickets_duplicates_skipped_total[5m]) * 60",
          "legendFormat": "duplicates skipped/min"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Gateway Auth Success vs Failure",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "rate(ticketblitz_gateway_auth_total{result=\"success\"}[5m]) * 60",
          "legendFormat": "success/min"
        },
        {
          "expr": "sum(rate(ticketblitz_gateway_auth_total{result=\"failure\"}[5m])) by (reason) * 60",
          "legendFormat": "failure ({{reason}})/min"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Rate Limit Rejections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "rate(ticketblitz_gateway_ratelimit_rejected_total[5m]) * 60",
          "legendFormat": "rejected/min"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "fixedColor": "red", "mode": "fixed" } } },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    }
  ],
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Business Metrics",
  "uid": "ticketblitz-business-metrics",
  "version": 1
}
